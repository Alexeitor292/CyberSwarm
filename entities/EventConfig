{
  "name": "EventConfig",
  "type": "object",
  "properties": {
    "event_date": {
      "type": "string",
      "format": "date",
      "description": "Date of the event"
    },
    "event_time": {
      "type": "string",
      "description": "Event start time"
    },
    "venue_name": {
      "type": "string",
      "description": "Name of the venue"
    },
    "venue_name_line_1": {
      "type": "string",
      "description": "Venue title line 1 shown above the street address"
    },
    "venue_name_line_2": {
      "type": "string",
      "description": "Optional venue title line 2 shown above the street address"
    },
    "venue_address": {
      "type": "string",
      "description": "Full address of the venue"
    },
    "google_maps_embed_url": {
      "type": "string",
      "description": "Google Maps iframe HTML or iframe src URL used for the public event map"
    },
    "google_form_embed_url": {
      "type": "string",
      "description": "Google Form embed URL for registration"
    },
    "tagline": {
      "type": "string",
      "description": "Event tagline"
    }
  },
  "required": [
    "event_date"
  ]
}
